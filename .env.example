# ============================================
# .env.example — Przykładowe zmienne środowiskowe
# Skopiowano ten plik jako .env i uzupełniono
# wartości przed uruchomieniem aplikacji.
# ============================================

# --- Aplikacja ---
APP_NAME=TaskFlow
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Baza danych PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow_user
POSTGRES_PASSWORD=taskflow_secret_password

# --- Pełny URL połączenia z bazą danych ---
# (Generowany automatycznie w config.py na podstawie powyższych zmiennych)
# DATABASE_URL=postgresql+asyncpg://taskflow_user:taskflow_secret_password@postgres:5432/taskflow

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Nginx ---
NGINX_PORT=80
