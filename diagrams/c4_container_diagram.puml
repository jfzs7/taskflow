@startuml C4_Container_Diagram_TaskFlow

skinparam backgroundColor #FEFEFE
skinparam defaultFontName Arial
skinparam defaultFontSize 11

skinparam rectangle {
    BackgroundColor #D6E8FF
    BorderColor #4A90D9
    BorderThickness 2
}
skinparam database {
    BackgroundColor #FFF3CD
    BorderColor #DAA520
}
skinparam actor {
    BackgroundColor #D4EDDA
    BorderColor #2E8B57
}
skinparam ArrowColor #444444
skinparam NoteBorderColor #AAAAAA
skinparam NoteBackgroundColor #FFFFF0

title Diagram Kontenerow (C4 Level 2) - System TaskFlow

actor "Uzytkownik\n(Przegladarka)" as user
rectangle "GitHub GHCR\n[Zewnetrzny rejestr obrazow]" as ghcr

package "System TaskFlow (Kubernetes / Docker Compose)" {

    rectangle "Nginx Reverse Proxy\n[nginx:alpine]\nOdbiera ruch HTTP :80\nPrzekazuje ruch do API" as nginx

    rectangle "Backend API\n[Python 3.12 / FastAPI / Uvicorn]\nGlowna logika biznesowa\nCRUD REST API + metryki /metrics" as api

    database "PostgreSQL 16\n[StatefulSet K8s + PVC]\nRelacyjna baza danych\nasyncpg / TCP 5432" as postgres

    database "Redis 7\n[StatefulSet K8s + PVC]\nCache in-memory\nCache-Aside TTL=60s / TCP 6379" as redis

    rectangle "Prometheus\n[prom/prometheus]\nZbiera metryki co 15s (pull)" as prometheus

    rectangle "Grafana\n[grafana/grafana]\nWizualizacja metryk / dashboardy" as grafana
}

user --> nginx : "HTTP :80"
nginx --> api : "HTTP :8000 (proxy_pass)"
api --> postgres : "SQL (asyncpg)"
api --> redis : "Cache GET/SET/DEL"
prometheus --> api : "GET /metrics (pull)"
grafana --> prometheus : "PromQL"
ghcr ..> api : "image pull"

note right of redis
  Cache-Aside pattern:
  HIT: odpowiedz z Redis < 5ms
  MISS: zapytanie do PostgreSQL
  + zapis do Redis z TTL=60s
end note

@enduml
